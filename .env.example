# ── Projekkt — Next.js App ──────────────────────────────────────────────────
# Copy to .env.local and fill in your values. NEVER commit .env.local to git.

# PostgreSQL connection string (Railway provides this)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT secret — generate with: openssl rand -hex 32
JWT_SECRET=your_jwt_secret_here

# Brevo (email verification + transactional emails)
BREVO_API_KEY=your_brevo_api_key_here
FROM_EMAIL=noreply@shaddies.space
FROM_NAME=Projekkt

# Flutterwave
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-xxxxxxxxxxxxxxxx
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-xxxxxxxxxxxxxxxx
FLUTTERWAVE_ENCRYPTION_KEY=xxxxxxxxxxxxxxxx

# Python microservice URL (Railway deployment)
PYTHON_SERVICE_URL=https://your-python-service.railway.app

# Shared secret between Next.js and Python service
# Generate with: openssl rand -hex 32
INTERNAL_API_SECRET=change_this_to_a_long_random_secret

# App URL (for email links + payment redirects)
NEXT_PUBLIC_APP_URL=https://projekkt.shaddies.space
